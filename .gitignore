# ---------------------------------------------------------------------
# Salidas de compilación (compílalas tú — ver specs/exercises/COMMON_BUILD.md)
# ---------------------------------------------------------------------
**/build/
**/build_lr1110_l4/
**/build_lr11*_l4/
lbm_lib/build/
*.o
*.d
*.lst
*.map

# ---------------------------------------------------------------------
# Binarios de firmware — por defecto NO se versionan (salidas de build)
# ---------------------------------------------------------------------
*.bin
*.elf
*.hex

# Excepción: los binarios FLASHEABLES de cada ejercicio SÍ se versionan, para que
# un clon venga listo para flashear (recompilables con specs/exercises/COMMON_BUILD.md).
!specs/exercises/*/artifacts/*.bin
!specs/exercises/*/artifacts/*.hex
!specs/exercises/*/artifacts/*.elf

# ---------------------------------------------------------------------
# Sistema operativo / editores
# ---------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*~
.vscode/

# Ficheros de notas/secretos que NO deben versionarse
**/ignorar.txt
